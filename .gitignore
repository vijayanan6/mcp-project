*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/

# Environment & secrets
.env
.env.*
*.key

# Sensitive documents — never commit personal files
knowledge_base/*.pdf
knowledge_base/*.txt
knowledge_base/*.docx

# Virtual environments
venv/
.venv/
env/

# IDE
.vscode/
.idea/
*.suo

# Local data directory (local only — not committed): data.db, chroma_db/, and
# any other artifact that lands here (e.g. pre-migration backups like
# data.db.bak-*) — widened from two literal paths after one such backup file
# showed up as untracked and wasn't covered by the narrower pattern.
data/

# OS
.DS_Store
Thumbs.db

# LinkedIn drafts — personal, not project code
docs/LINKEDIN_POSTS.md

# Logs
*.log
logs/

# Temp files
*.tmp
*.temp

# Playwright MCP output — screenshots and page snapshots, may contain session data
.playwright-mcp/
dashboard-test.png

# Claude Code internal files (local config/cache) — but track published skills
.claude/*
!.claude/skills/
!.claude/skills/**

# Testing (pytest — Phase pre-Docker)
.pytest_cache/
.coverage
htmlcov/
coverage.xml

# Type checking
.mypy_cache/

# GCP — service account keys (NEVER commit these)
*service-account*.json
*-key.json
service_account.json
gcp-key.json

# Certificates & private keys
*.pem
*.p12
*.pfx

# Docker local overrides (Phase 1)
docker-compose.override.yml
.docker/

# React / Node (Phase 2)
node_modules/
.next/
.env.local
.env.development.local
.env.production.local
frontend/dist/
frontend/build/
